{
  "mcpServers": {
    "wirenest": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "cd /d mcp && .\\node_modules\\.bin\\tsx src\\index.ts"
      ],
      "env": {
        "WIRENEST_URL": "http://localhost:5180",
        "PIHOLE_URL": "${PIHOLE_URL:-}",
        "PIHOLE_PASSWORD": "${PIHOLE_PASSWORD:-}",
        "PFSENSE_URL": "${PFSENSE_URL:-}",
        "PFSENSE_API_KEY": "${PFSENSE_API_KEY:-}",
        "PFSENSE_API_SECRET": "${PFSENSE_API_SECRET:-}",
        "OPNSENSE_URL": "${OPNSENSE_URL:-}",
        "OPNSENSE_API_KEY": "${OPNSENSE_API_KEY:-}",
        "OPNSENSE_API_SECRET": "${OPNSENSE_API_SECRET:-}"
      }
    }
  }
}
