{
  "name": "mcp-homelab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for homelab infrastructure management. Connects to pfSense, OPNsense, Pi-hole, Proxmox, and more. Uses WireNest as single source of truth.",
